<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Arka plan dekorasyon -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="#0800E5FF"
        android:layout_marginTop="-80dp"
        android:layout_marginEnd="-80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Logo & İkon -->
    <LinearLayout
        android:id="@+id/layoutLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="70dp">

        <!-- Blok karakter ikonu -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@drawable/bg_icon_circle"
            android:padding="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NX GO"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginTop="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesabına giriş yap"
            android:textColor="#8899BB"
            android:textSize="13sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Giriş Formu -->
    <LinearLayout
        android:id="@+id/layoutForm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutLogo"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        android:layout_marginTop="36dp">

        <!-- Kullanıcı adı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KULLANICI ADI"
            android:textColor="#8899BB"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Kullanıcı adını gir"
            android:textColor="#FFFFFF"
            android:textColorHint="#3A4A6B"
            android:textSize="15sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:singleLine="true"/>

        <!-- Şifre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ŞİFRE"
            android:textColor="#8899BB"
            android:textSize="10sp"
            android:letterSpacing="0.15"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Şifreni gir"
            android:textColor="#FFFFFF"
            android:textColorHint="#3A4A6B"
            android:textSize="15sp"
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:singleLine="true"/>

        <!-- Hata mesajı -->
        <TextView
            android:id="@+id/tvError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF5252"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <!-- Giriş butonu -->
        <TextView
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="GİRİŞ YAP"
            android:textColor="#0A0E1A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:background="@drawable/bg_button_cyan"
            android:layout_marginTop="24dp"/>
    </LinearLayout>

    <!-- Alt kayıt linki -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesabın yok mu?  "
            android:textColor="#8899BB"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/btnGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kayıt Ol"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
